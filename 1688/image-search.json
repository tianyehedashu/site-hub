{
  "name": "1688 · 以图搜款（单页）",
  "description": "Upload image via mtop + fetch imageSearchOfferResultViewService (one page). Cross-border sourcing.",
  "auth": {
    "type": "cookie",
    "hint": "在本标签页登录 1688 买家账号；首次建议打开 www.1688.com 以写入 _m_h5_tk"
  },
  "navigate_url": "https://www.1688.com/",
  "mode": "js",
  "script": "",
  "_ziniao_1688_route": "image-search",
  "vars": {
    "image": {
      "type": "file",
      "required": true,
      "description": "待搜图片：本地路径、http(s) URL 或 base64"
    },
    "begin_page": {
      "type": "int",
      "default": 1,
      "description": "结果页码（从 1 起）"
    },
    "page_size": {
      "type": "int",
      "default": 40,
      "description": "每页条数（约 10–60）"
    }
  },
  "body": {
    "image": "{{image}}",
    "begin_page": "{{begin_page}}",
    "page_size": "{{page_size}}"
  }
}
